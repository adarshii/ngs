# ─── Environment Configuration Template ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file to version control.

# ─── Reference Genome ─────────────────────────────────────────────────────────
# Absolute path to the GRCh38 reference FASTA
REFERENCE_GENOME=/path/to/data/reference/GRCh38.fa

# ─── Tool Paths (only needed if tools are not on PATH) ────────────────────────
BWA_PATH=bwa
SAMTOOLS_PATH=samtools
GATK_PATH=gatk
TRIMMOMATIC_PATH=trimmomatic
FASTQC_PATH=fastqc
VEP_PATH=vep

# ─── GATK / Java memory ───────────────────────────────────────────────────────
GATK_JAVA_MEM=8G
PICARD_JAVA_MEM=8G

# ─── Pipeline Directories ─────────────────────────────────────────────────────
DATA_DIR=data
RESULTS_DIR=results
LOGS_DIR=results/logs

# ─── Optional: Notification settings ─────────────────────────────────────────
# Slack webhook for pipeline completion notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Optional: Cloud storage ──────────────────────────────────────────────────
# AWS S3 bucket for result archiving (optional)
# AWS_S3_BUCKET=s3://my-ngs-results
# AWS_REGION=us-east-1
